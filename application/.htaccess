    <IfModule authz_core_module>
        Require all denied
    </IfModule>
    <IfModule !authz_core_module>
        Deny from all
    </IfModule>
    RewriteEngine On
    RewriteMap tolower int:tolower
    RewriteRule ^(.+) ${tolower:$1} [R,L]
    RewriteCond %{HTTP_REFERER} !^http://localhost/SS/ [NC]
    RewriteRule \.(jpg|jpeg|png|gif|pdf)$ - [F]
